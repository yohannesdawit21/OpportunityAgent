PORT=3001
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
# Optional: override the default model (llama-3.3-70b-versatile). Falls back automatically if unavailable.
GROQ_MODEL=llama-3.3-70b-versatile
# Set to "true" to skip the Groq API and use deterministic seed responses
USE_AGENT_FALLBACK=false
